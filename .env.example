# Taksym streamer — copy to .env on the VPS and fill in the values.
# Anything left blank means that platform is skipped (both for streaming
# and for the chat bot).

# ─── Stream destinations ────────────────────────────────────────────────

# Twitch: get from https://dashboard.twitch.tv/u/<channel>/settings/stream
TWITCH_STREAM_KEY=

# YouTube: enable Live in YouTube Studio first (24h wait if first time),
# then https://studio.youtube.com/channel/UC.../livestreaming → "Stream key"
YOUTUBE_STREAM_KEY=

# Kick: https://dashboard.kick.com/settings/stream — Stream Key + Stream URL
KICK_STREAM_KEY=
# Kick RTMP base URL (without the final slash and key). Defaults to the
# generic EU ingest; override if your dashboard shows a different region.
# KICK_RTMP_URL=rtmps://fa723fc1b171.global-contribute.live-video.net:443/app

# ─── Twitch chat bot ────────────────────────────────────────────────────

# OAuth chat token for the bot user. Easiest: log into the bot account in
# the browser, then visit https://twitchtokengenerator.com/ → "Bot Chat
# Token" → copy the "oauth:..." value here.
TWITCH_CHAT_OAUTH=
# Defaults to taksymofficial — set if streaming on a different channel.
# TWITCH_CHANNEL=taksymofficial
# TWITCH_BOT_USER=taksymofficial

# ─── Kick chat bot ──────────────────────────────────────────────────────

# Read-only listener works without auth (just KICK_CHANNEL_ID).
# Posting back to chat needs KICK_CHAT_TOKEN (a session token; grab from
# devtools when sending a message manually) + KICK_CHANNEL_ID.
KICK_CHANNEL_ID=
KICK_CHAT_TOKEN=
# KICK_CHANNEL_SLUG=taksymofficial

# ─── YouTube chat bot ───────────────────────────────────────────────────

# Requires a one-time OAuth consent. Easiest path:
#   1. Create OAuth client in Google Cloud Console → APIs & Services
#      → Credentials → "Desktop app"
#   2. Add scope youtube.force-ssl, get a refresh token via the
#      OAuth Playground (https://developers.google.com/oauthplayground)
#   3. Paste the three values here
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# ─── Tuning (optional) ──────────────────────────────────────────────────

# Auto-post brand line into all chats every N minutes (0 to disable).
# CHAT_AUTOPOST_INTERVAL_MIN=10

# Encoding defaults (matched to a 1 vCPU / 1 GB VPS).
# STREAM_WIDTH=1280
# STREAM_HEIGHT=720
# STREAM_FPS=30
# STREAM_VBITRATE=3500k
# STREAM_ABITRATE=160k
# STREAM_PRESET=ultrafast

# Brand
# BRAND_URL=taksym.com
# SITE_ORIGIN=https://www.taksym.com
# CATALOG_URL=https://www.taksym.com/api/songs
# MIX_API_URL=https://www.taksym.com/api/mood-mix
